{
  "name": "nimbus-cloud",
  "version": "0.1.0",
  "description": "Nimbus Cloud desktop app",
  "author": "Nimbus Cloud",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "node tools/obfuscate-build.js"
  },
  "build": {
    "appId": "com.nimbus.cloud",
    "productName": "Nimbus Cloud",
    "files": [
      "src/**/*",
      "package.json",
      "logo.png"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "logo.png",
      "sign": null
    },
    "mac": {
      "icon": "logo.png"
    },
    "linux": {
      "icon": "logo.png"
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "javascript-obfuscator": "^4.1.1"
  }
}
